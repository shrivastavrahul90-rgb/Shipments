<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Operations console</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --canvas:#F6F7F9; --card:#FFFFFF; --line:#EAEBF0; --line2:#E0E2EA;
    --ink:#191A2C; --muted:#6A6E82; --faint:#9A9EB2;
    --sidebar:#15162B; --sidebar-2:#1E2040; --sidebar-tx:#A9ADC6; --sidebar-tx2:#6E7299;
    --accent:#5B5BD6; --accent-soft:#ECECFB;
    --display:"Space Grotesk",system-ui,sans-serif;
    --sans:"Inter",system-ui,-apple-system,sans-serif;
    --mono:"JetBrains Mono",ui-monospace,Menlo,Consolas,monospace;
    --shadow:0 1px 2px rgba(20,22,44,.04),0 6px 20px rgba(20,22,44,.05);
    --radius:16px; --radius-sm:10px;
  }
  *{box-sizing:border-box}
  html,body{margin:0}
  body{background:var(--canvas);color:var(--ink);font-family:var(--sans);font-size:14px;-webkit-font-smoothing:antialiased}
  .layout{display:flex;min-height:100vh}

  .side{width:248px;background:var(--sidebar);color:#fff;padding:26px 18px;flex-shrink:0;
    display:flex;flex-direction:column;gap:30px;position:sticky;top:0;height:100vh}
  .logo{display:flex;align-items:center;gap:11px}
  .logo .mark{width:34px;height:34px;border-radius:10px;background:var(--accent);display:flex;align-items:center;
    justify-content:center;color:#fff;flex-shrink:0}
  .logo .mark svg{width:19px;height:19px}
  .logo .t1{font-family:var(--display);font-weight:700;font-size:15px;letter-spacing:-.01em;line-height:1.1}
  .logo .t2{font-size:11px;color:var(--sidebar-tx2);letter-spacing:.06em;text-transform:uppercase;margin-top:1px}
  .navlabel{font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--sidebar-tx2);padding:0 10px;margin-bottom:8px}
  .nav{display:flex;flex-direction:column;gap:3px}
  .nav button{display:flex;align-items:center;gap:11px;width:100%;text-align:left;padding:11px 12px;border:none;
    background:none;border-radius:11px;cursor:pointer;font-size:13.5px;color:var(--sidebar-tx);font-family:var(--sans);
    font-weight:500;transition:background .15s,color .15s}
  .nav button svg{width:18px;height:18px;flex-shrink:0;opacity:.85}
  .nav button:hover{background:var(--sidebar-2);color:#fff}
  .nav button.active{background:var(--accent);color:#fff}
  .nav button.active svg{opacity:1}
  .side .foot{margin-top:auto;font-size:11px;color:var(--sidebar-tx2);line-height:1.6;padding:0 10px}

  .main{flex:1;padding:28px 34px 64px;max-width:1180px;animation:fade .4s ease}
  @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .top{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:6px;gap:18px;flex-wrap:wrap}
  .page-k{font-size:11px;letter-spacing:.13em;color:var(--faint);text-transform:uppercase;font-weight:600}
  .page-h{font-family:var(--display);font-size:27px;font-weight:600;margin-top:3px;letter-spacing:-.02em}
  .synced{font-size:12px;color:var(--faint);display:flex;align-items:center;gap:6px}
  .synced .dot{width:7px;height:7px;border-radius:50%;background:#16A34A;box-shadow:0 0 0 3px rgba(22,163,74,.15)}

  .ctrls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin:18px 0 4px}
  .seg{display:flex;background:var(--card);border:1px solid var(--line2);border-radius:10px;overflow:hidden}
  .seg button{padding:8px 13px;border:none;background:none;font-size:12.5px;font-weight:500;color:var(--muted);
    cursor:pointer;font-family:var(--sans);border-right:1px solid var(--line)}
  .seg button:last-child{border-right:none}
  .seg button:hover{background:#F3F3F8;color:var(--ink)}
  .seg button.on{background:var(--ink);color:#fff}
  .datebox{display:flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--line2);
    border-radius:10px;padding:5px 11px}
  .datebox svg{width:15px;height:15px;color:var(--faint)}
  .datebox input{border:none;background:none;outline:none;font-size:12.5px;font-family:var(--sans);color:var(--ink);width:112px}
  .datebox .arrow{color:var(--faint);font-size:12px}
  .iconbtn{width:36px;height:36px;border:1px solid var(--line2);background:var(--card);border-radius:10px;cursor:pointer;
    display:flex;align-items:center;justify-content:center;color:var(--muted)}
  .iconbtn:hover{background:#F3F3F8;color:var(--ink)}
  .iconbtn svg{width:16px;height:16px}
  .rangenote{font-size:12px;color:var(--faint);margin:10px 0 18px}

  .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
  .hero{padding:26px 28px;margin-bottom:18px;display:flex;align-items:center;gap:20px}
  .hero .ring{width:62px;height:62px;border-radius:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .hero .ring svg{width:28px;height:28px}
  .hero .n{font-family:var(--display);font-size:50px;font-weight:700;line-height:1;letter-spacing:-.03em}
  .hero .lbl{font-size:14.5px;color:var(--muted);margin-top:4px;max-width:380px}

  .toolbar{display:flex;gap:10px;align-items:center;padding:14px 18px;border-bottom:1px solid var(--line);flex-wrap:wrap}
  .search{flex:1;min-width:200px;display:flex;align-items:center;gap:9px;color:var(--faint)}
  .search svg{width:16px;height:16px}
  .search input{flex:1;border:none;background:none;outline:none;font-size:14px;font-family:var(--sans);color:var(--ink)}
  select{padding:8px 11px;border:1px solid var(--line2);border-radius:9px;background:var(--card);font-size:12.5px;
    font-family:var(--sans);color:var(--ink);cursor:pointer}
  .count{font-size:12px;color:var(--faint);font-family:var(--mono);white-space:nowrap}
  table{width:100%;border-collapse:collapse}
  th{text-align:left;font-size:10.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--faint);
    font-weight:600;padding:13px 18px;border-bottom:1px solid var(--line)}
  td{padding:14px 18px;border-bottom:1px solid var(--line);font-size:13.5px;vertical-align:middle}
  tbody tr:last-child td{border-bottom:none}
  tbody tr{transition:background .12s}
  tbody tr:hover{background:#FAFAFD}
  .num{font-family:var(--mono);text-align:right;font-weight:500}
  .order{font-family:var(--mono);font-weight:600;letter-spacing:-.01em}
  .awb{font-family:var(--mono);color:var(--muted);font-size:12.5px}
  .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 11px;border-radius:8px;font-size:12px;font-weight:600;
    text-transform:capitalize;letter-spacing:.01em}
  .pill::before{content:"";width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0}
  .red{color:#DC2626;font-weight:700}
  .empty{padding:46px 34px;text-align:center;color:var(--faint);font-size:14px}

  .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(178px,1fr));gap:14px}
  .stat{padding:18px 20px}
  .stat .k{font-size:12.5px;color:var(--muted);font-weight:500}
  .stat .v{font-family:var(--display);font-size:32px;font-weight:600;margin-top:8px;letter-spacing:-.02em}
  .stat .s{font-size:11.5px;color:var(--faint);margin-top:3px}

  .fnl-head{font-family:var(--display);font-size:16px;font-weight:600;letter-spacing:-.01em}
  .fnl-sub{font-size:12.5px;color:var(--faint);margin-top:3px}
  .funnel{display:flex;flex-direction:column;gap:11px;margin-top:20px}
  .frow{display:flex;align-items:center;gap:16px}
  .flabel{width:138px;text-align:right;font-size:13px;color:var(--muted);font-weight:500;flex-shrink:0}
  .ftrack{flex:1;background:#F1F2F6;border-radius:10px;height:42px;display:flex;align-items:center;padding:0;overflow:hidden}
  .fbar{height:100%;border-radius:10px;display:flex;align-items:center;padding:0 14px;color:#fff;font-family:var(--mono);
    font-size:13px;font-weight:600;white-space:nowrap;min-width:62px;transition:width .5s cubic-bezier(.2,.7,.2,1)}
  .fbar .pc{margin-left:auto;opacity:.82;font-weight:500;padding-left:12px}

  .fbar2{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--muted);margin-bottom:18px;flex-wrap:wrap}
  .fbar2 svg{width:16px;height:16px;color:#16A34A;flex-shrink:0}
  .fbar2 .clr{margin-left:auto;border:1px solid var(--line2);background:var(--card);padding:7px 13px;border-radius:9px;
    cursor:pointer;font-size:12.5px;font-weight:600;color:var(--ink)}
  .fbar2 .clr:hover{background:#F3F3F8}
  .rcards{display:grid;grid-template-columns:repeat(auto-fit,minmax(176px,1fr));gap:13px;margin-bottom:20px}
  .rcard{padding:16px 18px;cursor:pointer;transition:transform .12s,box-shadow .12s,border-color .12s}
  .rcard:hover{transform:translateY(-2px)}
  .rcard.on{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-soft),var(--shadow)}
  .rcard .rk{font-size:12.5px;color:var(--muted);font-weight:500;display:flex;align-items:center;gap:7px}
  .rcard .rk .d{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .rcard .rv{font-family:var(--display);font-size:28px;font-weight:600;margin-top:9px;letter-spacing:-.02em}
  .rcard .rs{font-size:11.5px;color:var(--faint);margin-top:2px;font-family:var(--mono)}
  .drop{border:2px dashed var(--line2);border-radius:var(--radius);padding:50px 30px;text-align:center;background:var(--card)}
  .drop.drag{border-color:var(--accent);background:var(--accent-soft)}
  .drop>svg{width:36px;height:36px;color:var(--faint);margin-bottom:14px}
  .drop .dt{font-family:var(--display);font-size:18px;font-weight:600}
  .drop .ds{font-size:13px;color:var(--muted);margin:8px auto 0;max-width:440px;line-height:1.55}
  .drop label{display:inline-block;margin-top:18px;padding:10px 20px;background:var(--accent);color:#fff;
    border-radius:10px;cursor:pointer;font-size:13.5px;font-weight:600}
  .drop label:hover{filter:brightness(1.06)}

  .banner{padding:15px 18px;border-radius:12px;margin-bottom:16px;font-size:13px;border:1px solid}
  .banner.err{background:#FCECEC;border-color:#F6CFCF;color:#991B1B}
  .banner.warn2{background:#FEF4E6;border-color:#F4DEB5;color:#92580A}

  @media(max-width:820px){
    .layout{flex-direction:column}
    .side{width:auto;height:auto;position:static;flex-direction:row;align-items:center;gap:18px;padding:14px 16px;flex-wrap:wrap}
    .side .foot{display:none}.navlabel{display:none}
    .nav{flex-direction:row;flex-wrap:wrap;gap:6px}
    .main{padding:22px 16px 50px}
    .flabel{width:96px;font-size:12px}
  }
  @media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>
<div class="layout">
  <aside class="side">
    <div class="logo">
      <div class="mark"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/></svg></div>
      <div><div class="t1">Shipments</div><div class="t2">Operations</div></div>
    </div>
    <div>
      <div class="navlabel">Console</div>
      <nav class="nav" id="nav">
        <button data-view="stuck" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><span>Stuck shipments</span></button>
        <button data-view="all"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 9.4 7.5 4.21M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/></svg><span>All shipments</span></button>
        <button data-view="overview"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg><span>Overview</span></button>
        <button data-view="recon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg><span>COD reconciliation</span></button>
      </nav>
    </div>
    <div class="foot">Live from NimbusPost<br>via Supabase</div>
  </aside>

  <main class="main">
    <div class="top">
      <div>
        <div class="page-k" id="pageK">Console</div>
        <div class="page-h" id="pageH">Loading…</div>
      </div>
      <div class="synced" id="synced"></div>
    </div>

    <div class="ctrls" id="ctrls">
      <div class="datebox">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <input type="date" id="from" title="From date">
        <span class="arrow">→</span>
        <input type="date" id="to" title="To date">
      </div>
      <div class="seg" id="presets">
        <button data-preset="15">15d</button>
        <button data-preset="30">30d</button>
        <button data-preset="90">90d</button>
        <button data-preset="all">All</button>
      </div>
      <button class="iconbtn" id="refresh" title="Reload from database">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
      </button>
    </div>
    <div class="rangenote" id="rangenote"></div>
    <div id="content"><div class="card empty">Connecting to your data…</div></div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script>
const SUPABASE_URL = "https://myndamxcarcrlzxdlirh.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im15bmRhbXhjYXJjcmx6eGRsaXJoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0NzYzODEsImV4cCI6MjA5ODA1MjM4MX0.oPG3UvLD-jYi-6fGyvj9W24prUZ2-6emp9oZhbt2SmE";

const STALE_HOURS = 48;
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let ALL = [];
let view = "stuck";
let search = "";
let statusFilter = "";
let deliveredFilter = "all";

function fmt(d){ return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0"); }
function todayStr(){ return fmt(new Date()); }
function addDaysStr(n){ const d=new Date(); d.setDate(d.getDate()+n); return fmt(d); }
let dateFrom = addDaysStr(-15);
let dateTo = todayStr();

const $ = (id) => document.getElementById(id);
const inr = (n) => isFinite(n)
  ? new Intl.NumberFormat("en-IN",{style:"currency",currency:"INR",maximumFractionDigits:0}).format(n)
  : "—";
const movedAt = (r) => new Date(r.last_event_at || r.status_changed_at || Date.now());
const hoursStuck = (r) => (Date.now() - movedAt(r).getTime())/3600000;
const isStuck = (r) => !r.is_terminal && hoursStuck(r) >= STALE_HOURS;

const STAGE = {
  total:    {solid:"#22243F", bg:"#E9E9F1", fg:"#22243F"},
  pending:  {solid:"#C77807", bg:"#FBF0DC", fg:"#8A5106"},
  transit:  {solid:"#2F6FED", bg:"#E6EFFE", fg:"#1A4FB8"},
  exception:{solid:"#DC2626", bg:"#FBE9E9", fg:"#9F1A1A"},
  ofd:      {solid:"#0E9384", bg:"#E0F4F1", fg:"#0A6B60"},
  rto:      {solid:"#C2410C", bg:"#FAE9DF", fg:"#9A3412"},
  delivered:{solid:"#16A34A", bg:"#E5F6EC", fg:"#127A39"},
  other:    {solid:"#6B7280", bg:"#EEF0F3", fg:"#4B5563"},
};
function stageOf(s){
  s=(s||"").toLowerCase();
  if(s.includes("rto")) return "rto";
  if(s.includes("exception")||s.includes("undeliver")||s.includes("fail")||s.includes("ndr")) return "exception";
  if(s.includes("out for")||s.includes("ofd")) return "ofd";
  if(s.includes("transit")) return "transit";
  if(s.includes("pending")||s.includes("pickup")||s.includes("manifest")||s.includes("booked")) return "pending";
  if(s.includes("delivered")) return "delivered";
  return "other";
}

function rowDate(r){
  if(r.created) return String(r.created).slice(0,10);
  if(r.last_event_at) return String(r.last_event_at).slice(0,10);
  if(r.status_changed_at) return String(r.status_changed_at).slice(0,10);
  return "";
}
function inWindow(r){
  const d = rowDate(r);
  if(!d) return true;
  if(dateFrom && d < dateFrom) return false;
  if(dateTo && d > dateTo) return false;
  return true;
}
function windowed(){ return ALL.filter(inWindow); }

const esc = (s) => String(s==null?"":s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));
function statusPill(s){
  const p = STAGE[stageOf(s)];
  return '<span class="pill" style="background:'+p.bg+';color:'+p.fg+'">'+esc(s||"unknown")+'</span>';
}
function payText(p){ return esc((p||"").toUpperCase()); }

async function loadData(){
  $("content").innerHTML = '<div class="card empty">Loading your shipments…</div>';
  try{
    const pageSize = 1000; let from = 0; const out = [];
    while(true){
      const { data, error } = await sb.from("shipments")
        .select("order_ref,awb,current_status,is_terminal,payment_type,cod_amount,last_event_at,status_changed_at,last_synced_at,created:raw->>created")
        .order("last_event_at",{ascending:false})
        .range(from, from+pageSize-1);
      if(error) throw error;
      out.push(...data);
      if(data.length < pageSize) break;
      from += pageSize;
    }
    ALL = out;
    updateSynced();
    render();
  }catch(e){
    $("pageH").textContent = "Couldn't load data";
    $("content").innerHTML =
      '<div class="banner err"><b>Could not read from Supabase.</b><br>'+esc(e.message||e)+
      '</div><div class="card empty">Check the URL and anon key, and that the read policy allows anonymous access.</div>';
  }
}

function updateSynced(){
  let latest = 0;
  ALL.forEach(r=>{ const t=Date.parse(r.last_synced_at||""); if(t>latest) latest=t; });
  if(!latest){ $("synced").innerHTML=""; return; }
  const mins = Math.round((Date.now()-latest)/60000);
  let txt = mins<1 ? "just now" : mins<60 ? mins+" min ago" :
            mins<1440 ? Math.round(mins/60)+" hr ago" : Math.round(mins/1440)+" days ago";
  $("synced").innerHTML = '<span class="dot"></span> Synced '+txt;
}

function applySearch(rows){
  if(!search.trim()) return rows;
  const q = search.trim().toLowerCase();
  return rows.filter(r => (r.order_ref||"").toLowerCase().includes(q) || (r.awb||"").toLowerCase().includes(q));
}

function setRangeNote(){
  const r = (!dateFrom && !dateTo) ? "all dates" : (dateFrom||"…")+"  →  "+(dateTo||"…");
  $("rangenote").textContent = "Showing orders created " + r;
}

function render(){
  setRangeNote();
  const showCtrls = view!=="recon";
  $("ctrls").style.display = showCtrls?"flex":"none";
  $("rangenote").style.display = showCtrls?"block":"none";
  document.querySelectorAll("#nav button").forEach(b=>b.classList.toggle("active", b.dataset.view===view));
  if(view==="stuck") return renderStuck();
  if(view==="all") return renderAll();
  if(view==="recon") return renderRecon();
  return renderOverview();
}

function renderStuck(){
  $("pageK").textContent = "Console";
  $("pageH").textContent = "Stuck shipments";
  const base = windowed().filter(isStuck);
  const stuck = applySearch(base).sort((a,b)=>hoursStuck(b)-hoursStuck(a));
  const total = base.length;
  const rows = stuck.map(r=>{
    const h = hoursStuck(r);
    const hCls = h>72 ? ' class="num red"' : ' class="num"';
    return '<tr>'+
      '<td class="order">'+esc(r.order_ref)+'</td>'+
      '<td class="awb">'+esc(r.awb)+'</td>'+
      '<td>'+statusPill(r.current_status)+'</td>'+
      '<td'+hCls+'>'+h.toFixed(1)+'h</td>'+
      '<td>'+payText(r.payment_type)+'</td>'+
      '<td class="num">'+inr(Number(r.cod_amount))+'</td>'+
    '</tr>';
  }).join("");
  const warn = total>0;
  const ringBg = warn ? "#FBE9E9" : "#E5F6EC";
  const ringFg = warn ? "#DC2626" : "#16A34A";
  const icon = warn
    ? '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>'
    : '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>';
  const hero = '<div class="card hero">'+
    '<div class="ring" style="background:'+ringBg+';color:'+ringFg+'"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'+icon+'</svg></div>'+
    '<div><div class="n" style="color:'+(warn?"#DC2626":"#16A34A")+'">'+total+'</div>'+
    '<div class="lbl">'+(warn?"order(s) stuck in the same stage for 48 hours or more":"all clear — every shipment in this range moved within 48 hours")+'</div></div></div>';
  const table = stuck.length===0
    ? '<div class="card empty">'+(total===0?"Nothing stuck in this date range.":"No matches for your search.")+'</div>'
    : '<div class="card"><div class="toolbar">'+searchBox()+'<span class="count">'+stuck.length+' of '+total+'</span></div>'+
      '<table><thead><tr><th>Order</th><th>AWB</th><th>Stage</th><th style="text-align:right">Stuck for</th><th>Payment</th><th style="text-align:right">Value</th></tr></thead><tbody>'+rows+'</tbody></table></div>';
  $("content").innerHTML = hero + table + zeroHint();
  wireSearch();
}

function renderAll(){
  $("pageK").textContent = "Console";
  $("pageH").textContent = "All shipments";
  let rows = windowed();
  if(statusFilter) rows = rows.filter(r=>(r.current_status||"")===statusFilter);
  if(deliveredFilter==="delivered") rows = rows.filter(r=>r.is_terminal);
  if(deliveredFilter==="not") rows = rows.filter(r=>!r.is_terminal);
  rows = applySearch(rows);
  const statuses = [...new Set(windowed().map(r=>r.current_status).filter(Boolean))].sort();
  const body = rows.map(r=>'<tr>'+
      '<td class="order">'+esc(r.order_ref)+'</td>'+
      '<td class="awb">'+esc(r.awb)+'</td>'+
      '<td>'+statusPill(r.current_status)+'</td>'+
      '<td>'+payText(r.payment_type)+'</td>'+
      '<td class="num">'+inr(Number(r.cod_amount))+'</td>'+
      '<td class="num" style="color:var(--muted);font-weight:400">'+esc(movedAt(r).toLocaleString("en-IN"))+'</td>'+
    '</tr>').join("");
  const toolbar = '<div class="toolbar">'+searchBox()+
    '<select id="fStatus"><option value="">All stages</option>'+
      statuses.map(s=>'<option '+(s===statusFilter?"selected":"")+'>'+esc(s)+'</option>').join("")+'</select>'+
    '<select id="fDeliv">'+
      '<option value="all"'+(deliveredFilter==="all"?" selected":"")+'>Delivered & not</option>'+
      '<option value="not"'+(deliveredFilter==="not"?" selected":"")+'>Not delivered</option>'+
      '<option value="delivered"'+(deliveredFilter==="delivered"?" selected":"")+'>Delivered</option>'+
    '</select>'+
    '<span class="count">'+rows.length+'</span></div>';
  $("content").innerHTML = '<div class="card">'+toolbar+
    (rows.length===0?'<div class="empty">No matches.</div>':
    '<table><thead><tr><th>Order</th><th>AWB</th><th>Stage</th><th>Payment</th><th style="text-align:right">Value</th><th style="text-align:right">Last moved</th></tr></thead><tbody>'+body+'</tbody></table>')+
    '</div>'+zeroHint();
  wireSearch();
  $("fStatus").onchange=e=>{statusFilter=e.target.value;renderAll();};
  $("fDeliv").onchange=e=>{deliveredFilter=e.target.value;renderAll();};
}

function renderOverview(){
  $("pageK").textContent = "Console";
  $("pageH").textContent = "Overview";
  const data = windowed();
  const total = data.length;

  const c = {rto:0,exception:0,ofd:0,transit:0,pending:0,delivered:0,other:0};
  data.forEach(r=>{ c[stageOf(r.current_status)]++; });

  const stages = [
    {label:"Total Orders",     n: total,       key:"total"},
    {label:"Pending Pickup",   n: c.pending,   key:"pending"},
    {label:"In Transit",       n: c.transit,   key:"transit"},
    {label:"Exception",        n: c.exception, key:"exception"},
    {label:"Out for Delivery", n: c.ofd,       key:"ofd"},
    {label:"RTO",              n: c.rto,       key:"rto"},
  ];
  const pct = (n)=> total>0 ? (n/total*100) : 0;
  const pctLabel = (n)=>{ if(total===0||n===0) return "0%"; const p=pct(n); return p<1?"<1%":Math.round(p)+"%"; };

  const funnelRows = stages.map(st=>{
    const w = pct(st.n);
    return '<div class="frow">'+
      '<div class="flabel">'+st.label+'</div>'+
      '<div class="ftrack"><div class="fbar" style="width:'+w.toFixed(2)+'%;background:'+STAGE[st.key].solid+'">'+
        '<span>'+st.n+'</span><span class="pc">'+pctLabel(st.n)+'</span></div></div></div>';
  }).join("");

  const funnel = '<div class="card" style="padding:24px 26px;margin-bottom:18px">'+
    '<div class="fnl-head">Shipment funnel</div>'+
    '<div class="fnl-sub">Share of orders by stage'+(total===0?'':' · '+total+' orders in range')+'</div>'+
    '<div class="funnel">'+funnelRows+'</div></div>';

  const delivered = c.delivered;
  const notDelivered = total - delivered;
  const cod = data.filter(r=>(r.payment_type||"").toLowerCase().includes("cod")).length;
  const prepaid = total - cod;
  const stuck = data.filter(isStuck).length;
  const openValue = data.filter(r=>!r.is_terminal).reduce((a,r)=>a+(Number(r.cod_amount)||0),0);
  const card=(k,v,s,col)=>'<div class="card stat"><div class="k">'+k+'</div><div class="v"'+(col?' style="color:'+col+'"':'')+'>'+v+'</div>'+(s?'<div class="s">'+s+'</div>':'')+'</div>';
  const cards = '<div class="cards">'+
    card("Total shipments", total) +
    card("Stuck 48h+", stuck, "need attention", stuck>0?"#DC2626":null) +
    card("Delivered", delivered, null, "#16A34A") +
    card("Not delivered", notDelivered) +
    card("COD vs prepaid", cod+" / "+prepaid) +
    card("Value in transit", inr(openValue), "all non-delivered") +
  '</div>';

  $("content").innerHTML = funnel + cards + zeroHint();
}

function zeroHint(){
  if(ALL.length>0) return "";
  return '<div class="banner warn2" style="margin-top:16px"><b>Connected, but 0 rows came back.</b> '+
    'This usually means the read policy is blocking anonymous access.</div>';
}

function searchBox(){
  return '<div class="search"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'+
    '<input id="searchInput" placeholder="Search by order number or AWB" value="'+esc(search)+'"></div>';
}
function wireSearch(){
  const el=$("searchInput"); if(!el) return;
  el.oninput=e=>{search=e.target.value;
    const pos=e.target.selectionStart;
    if(view==="stuck")renderStuck();else if(view==="all")renderAll();
    const n=$("searchInput"); if(n){n.focus();try{n.setSelectionRange(pos,pos);}catch(_){}}
  };
}

function setPreset(p){
  document.querySelectorAll("#presets button").forEach(b=>b.classList.toggle("on", b.dataset.preset===p));
}

/* ---------- COD reconciliation ---------- */
const RECON_TAT_DAYS = 7;
let depositFileName = "";
let recon = null;
let reconBucket = "unpaid";

const normAwb = s => String(s==null?"":s).trim();
const normOrd = s => String(s==null?"":s).trim().replace(/^#+/,"").toUpperCase();
const daysSince = iso => iso ? (Date.now()-new Date(iso).getTime())/86400000 : 999;
const isDeliveredCOD = r => stageOf(r.current_status)==="delivered" && (r.payment_type||"").toLowerCase().includes("cod");

function handleFile(file){
  depositFileName = file.name;
  const reader = new FileReader();
  reader.onload = e=>{
    try{
      const wb = XLSX.read(new Uint8Array(e.target.result), {type:"array"});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, {defval:""});
      computeRecon(rows);
      reconBucket = "unpaid";
      renderRecon();
    }catch(err){
      $("content").innerHTML = '<div class="banner err"><b>Could not read that file.</b><br>'+esc(err.message||err)+'</div>'+reconUploadHTML();
      wireDrop();
    }
  };
  reader.readAsArrayBuffer(file);
}

function computeRecon(rows){
  const empty = {unpaid:[],awaiting:[],mismatch:[],reconciled:[],unmatched:[],lines:0,checked:0};
  if(!rows || !rows.length){ recon = empty; return; }
  const keys = Object.keys(rows[0]);
  const find = (...subs)=>keys.find(k=>{const l=k.toLowerCase(); return subs.every(s=>l.includes(s));});
  const kAwb = find("awb") || find("waybill");
  const kOrd = find("order","id") || find("order");
  const kAmt = find("amount") || find("cod") || find("remit");
  const kDel = find("delivery");

  const deposits = rows.map(r=>({
    awb: normAwb(r[kAwb]),
    ord: normOrd(r[kOrd]),
    amt: parseFloat(String(r[kAmt]).replace(/[^0-9.\-]/g,"")) || 0,
    del: String(r[kDel]||""),
    rawOrd: String(r[kOrd]||"")
  })).filter(d=>d.awb||d.ord);

  const byAwb = new Map(), byOrd = new Map();
  deposits.forEach(d=>{ if(d.awb) byAwb.set(d.awb,d); if(d.ord) byOrd.set(d.ord,d); });

  const shipAwb = new Set(), shipOrd = new Set();
  ALL.forEach(r=>{ if(r.awb) shipAwb.add(normAwb(r.awb)); if(r.order_ref) shipOrd.add(normOrd(r.order_ref)); });

  const res = {unpaid:[],awaiting:[],mismatch:[],reconciled:[],unmatched:[],lines:deposits.length,checked:0};
  ALL.filter(isDeliveredCOD).forEach(r=>{
    res.checked++;
    const a = normAwb(r.awb), o = normOrd(r.order_ref);
    const dep = (a && byAwb.get(a)) || (o && byOrd.get(o)) || null;
    if(dep){
      const exp = Number(r.cod_amount)||0, got = dep.amt||0;
      if(exp>0 && got>0 && Math.abs(exp-got)>1) res.mismatch.push({r,exp,got,diff:got-exp});
      else res.reconciled.push({r,got});
    }else{
      const age = daysSince(r.last_event_at||r.status_changed_at);
      if(age>RECON_TAT_DAYS) res.unpaid.push({r,age});
      else res.awaiting.push({r,age});
    }
  });
  deposits.forEach(d=>{
    const inShip = (d.awb && shipAwb.has(d.awb)) || (d.ord && shipOrd.has(d.ord));
    if(!inShip) res.unmatched.push(d);
  });
  recon = res;
}

function reconUploadHTML(){
  return '<div class="drop" id="drop">'+
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>'+
    '<div class="dt">Upload your COD remittance file</div>'+
    '<div class="ds">CSV or Excel from NimbusPost. Each line is matched to your delivered COD orders by AWB, then anything delivered but unpaid past '+RECON_TAT_DAYS+' days gets flagged.</div>'+
    '<label for="codfile">Choose file</label>'+
    '<input type="file" id="codfile" accept=".csv,.xlsx,.xls" style="display:none">'+
    '</div>';
}
function wireDrop(){
  const inp = $("codfile");
  if(inp) inp.onchange = e=>{ if(e.target.files[0]) handleFile(e.target.files[0]); };
  const dz = $("drop"); if(!dz) return;
  ["dragenter","dragover"].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.add("drag");}));
  ["dragleave"].forEach(ev=>dz.addEventListener(ev,e=>{e.preventDefault();dz.classList.remove("drag");}));
  dz.addEventListener("drop",e=>{e.preventDefault();dz.classList.remove("drag"); if(e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);});
}

function tableCard(headers,body,aligns){
  const th = headers.map((h,i)=>'<th'+((aligns&&aligns[i]==="r")?' style="text-align:right"':'')+'>'+h+'</th>').join("");
  return '<div class="card"><table><thead><tr>'+th+'</tr></thead><tbody>'+body+'</tbody></table></div>';
}
const emptyCard = (m)=>'<div class="card empty">'+m+'</div>';
const tdN = (v)=>'<td class="num">'+v+'</td>';

function reconTable(){
  const b = reconBucket;
  if(b==="unpaid" || b==="awaiting"){
    const arr = recon[b].slice().sort((x,y)=>y.age-x.age);
    if(!arr.length) return emptyCard(b==="unpaid"?"No overdue unpaid COD orders — you're square.":"Nothing waiting inside the "+RECON_TAT_DAYS+"-day window.");
    const body = arr.map(({r,age})=>'<tr>'+
      '<td class="order">'+esc(r.order_ref)+'</td><td class="awb">'+esc(r.awb)+'</td>'+
      '<td>'+statusPill(r.current_status)+'</td>'+tdN(Math.round(age)+'d')+
      '<td>'+payText(r.payment_type)+'</td>'+tdN(inr(Number(r.cod_amount)))+'</tr>').join("");
    return tableCard(["Order","AWB","Stage","Delivered ago","Payment","Value"],body,[null,null,null,"r",null,"r"]);
  }
  if(b==="mismatch"){
    const arr = recon.mismatch;
    if(!arr.length) return emptyCard("No amount mismatches — every matched deposit equals the order value.");
    const body = arr.map(({r,exp,got,diff})=>'<tr>'+
      '<td class="order">'+esc(r.order_ref)+'</td><td class="awb">'+esc(r.awb)+'</td>'+
      tdN(inr(exp))+tdN(inr(got))+
      '<td class="num" style="color:'+(diff<0?"#DC2626":"#16A34A")+';font-weight:700">'+(diff>0?"+":"")+inr(diff)+'</td></tr>').join("");
    return tableCard(["Order","AWB","Expected","Deposited","Difference"],body,[null,null,"r","r","r"]);
  }
  if(b==="reconciled"){
    const arr = recon.reconciled;
    if(!arr.length) return emptyCard("No reconciled orders in this file yet.");
    const body = arr.map(({r,got})=>'<tr>'+
      '<td class="order">'+esc(r.order_ref)+'</td><td class="awb">'+esc(r.awb)+'</td>'+
      '<td style="color:var(--muted)">'+esc(movedAt(r).toLocaleDateString("en-IN"))+'</td>'+
      tdN(inr(got||Number(r.cod_amount)))+'</tr>').join("");
    return tableCard(["Order","AWB","Delivered","Deposited"],body,[null,null,null,"r"]);
  }
  const arr = recon.unmatched;
  if(!arr.length) return emptyCard("Every deposit line matched an order in your system.");
  const body = arr.map(d=>'<tr>'+
    '<td class="order">'+esc(d.rawOrd||("#"+d.ord))+'</td><td class="awb">'+esc(d.awb)+'</td>'+
    '<td style="color:var(--muted)">'+esc(d.del)+'</td>'+tdN(inr(d.amt))+'</tr>').join("");
  return tableCard(["Order ID (file)","AWB","Delivery date (file)","Amount"],body,[null,null,null,"r"]);
}

function renderRecon(){
  $("pageK").textContent = "Console";
  $("pageH").textContent = "COD reconciliation";
  if(!recon){
    $("content").innerHTML = reconUploadHTML();
    wireDrop();
    return;
  }
  const sumVal = arr=>arr.reduce((a,x)=>a+(Number(x.r?x.r.cod_amount:x.amt)||0),0);
  const sumDep = arr=>arr.reduce((a,x)=>a+(Number(x.got!=null?x.got:x.amt)||0),0);
  const buckets = [
    {key:"unpaid",     label:"Unpaid · overdue",     color:"#DC2626", n:recon.unpaid.length,     amt:sumVal(recon.unpaid)},
    {key:"awaiting",   label:"Awaiting · \u22647d",   color:"#C77807", n:recon.awaiting.length,   amt:sumVal(recon.awaiting)},
    {key:"mismatch",   label:"Amount mismatch",       color:"#C2410C", n:recon.mismatch.length,   amt:sumVal(recon.mismatch)},
    {key:"reconciled", label:"Reconciled",            color:"#16A34A", n:recon.reconciled.length, amt:sumDep(recon.reconciled)},
    {key:"unmatched",  label:"Unmatched deposits",    color:"#6B7280", n:recon.unmatched.length,  amt:sumDep(recon.unmatched)},
  ];
  const cards = buckets.map(b=>'<div class="card rcard'+(reconBucket===b.key?' on':'')+'" data-bk="'+b.key+'">'+
    '<div class="rk"><span class="d" style="background:'+b.color+'"></span>'+b.label+'</div>'+
    '<div class="rv">'+b.n+'</div><div class="rs">'+inr(b.amt)+'</div></div>').join("");
  const bar = '<div class="fbar2">'+
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'+
    'Checked <b style="color:var(--ink);font-weight:600">'+recon.checked+'</b> delivered COD orders against <b style="color:var(--ink);font-weight:600">'+esc(depositFileName)+'</b> ('+recon.lines+' deposit lines)'+
    '<button class="clr" id="clrRecon">Upload another file</button></div>';
  $("content").innerHTML = bar + '<div class="rcards">'+cards+'</div>' + reconTable();
  document.querySelectorAll(".rcard").forEach(c=>c.onclick=()=>{ reconBucket=c.dataset.bk; renderRecon(); });
  $("clrRecon").onclick = ()=>{ recon=null; depositFileName=""; renderRecon(); };
}

document.querySelectorAll("#nav button").forEach(b=>{
  b.onclick=()=>{view=b.dataset.view;search="";render();};
});
$("from").value = dateFrom;
$("to").value = dateTo;
$("from").onchange = e=>{ dateFrom=e.target.value; setPreset(""); render(); };
$("to").onchange = e=>{ dateTo=e.target.value; setPreset(""); render(); };
document.querySelectorAll("#presets button").forEach(b=>{
  b.onclick=()=>{
    const p=b.dataset.preset;
    if(p==="all"){ dateFrom=""; dateTo=""; }
    else { dateTo=todayStr(); dateFrom=addDaysStr(-parseInt(p,10)); }
    $("from").value=dateFrom; $("to").value=dateTo; setPreset(p); render();
  };
});
$("refresh").onclick=loadData;
setPreset("15");
loadData();
</script>
